# ── [10] Precios ──────────────────────────────────────────────
do_prices() {
    title
    echo -e "  ${BOLD}Editar precios de planes${NC}\n"
    RENOVAR="$PANEL_DIR/pages/renovar.php"
    [ ! -f "$RENOVAR" ] && echo -e "  ${RED}No encontrado renovar.php${NC}" && pause && return
    echo -e "  ${CYAN}Precios actuales:${NC}"
    grep -E "'mensal'|'trimestral'|'anual'|'vitalicio'" "$RENOVAR" | grep "preco" | \
      sed "s/.*'\(.*\)' =>.*'preco' => \([0-9.]*\).*/  \1: \$\2/" | head -4
    echo ""
    echo -e "  ${GREEN}[1]${NC} Mensual    ${GREEN}[2]${NC} Trimestral"
    echo -e "  ${GREEN}[3]${NC} Anual      ${GREEN}[4]${NC} Vitalicio"
    echo -e "  ${GREEN}[0]${NC} Volver"
    echo -ne "\n  Opción: "
    read POPT
    [ "$POPT" = "0" ] && return
    PLAN_MAP=([1]="mensal" [2]="trimestral" [3]="anual" [4]="vitalicio")
    PLAN="${PLAN_MAP[$POPT]}"
    [ -z "$PLAN" ] && return
    echo -ne "  Nuevo precio para $PLAN (ej: 9.99): "
    read NEWPRICE
    [ -z "$NEWPRICE" ] && return
    python3 -c "
import re
with open('$RENOVAR','r',encoding='utf-8',errors='replace') as f: c=f.read()
p=r\"('$PLAN'.*?'preco'\s*=>\s*)\d+\.?\d*\"
new=re.sub(p, lambda m: m.group(1)+'$NEWPRICE', c, flags=re.DOTALL)
open('$RENOVAR','w',encoding='utf-8').write(new)
print('OK')" && echo -e "  ${GREEN}✓ Precio de $PLAN actualizado a \$$NEWPRICE${NC}" || echo -e "  ${RED}✗ Error${NC}"
    sleep 2
}

# ── [11] Puertos ──────────────────────────────────────────────
do_ports() {
    title
    echo -e "  ${BOLD}Puertos activos${NC}\n"
    echo -e "  ${CYAN}TCP en escucha:${NC}"
    # Parsear ss: extraer dirección y solo el nombre del proceso (sin pid/fd)
    ss -tlnp 2>/dev/null | awk '
        /LISTEN/ {
            addr = $4
            proc = ""
            # Extraer primer nombre entre comillas del campo users:(("nombre",...))
            if (match($0, /users:\(\("([^"]+)"/, a)) {
                proc = a[1]
            } else if ($6 ~ /users:/) {
                n = split($6, p, "\"")
                if (n >= 2) proc = p[2]
            }
            printf "  %-28s %s\n", addr, proc
        }
    ' | sort -t: -k2 -n | head -20
    echo ""
    # Contar puertos únicos (no procesos)
    HTTP_CNT=$(ss -tlnp 2>/dev/null | awk '/LISTEN/ && /:80($| )/' | wc -l)
    HTTPS_CNT=$(ss -tlnp 2>/dev/null | awk '/LISTEN/ && /:443($| )/' | wc -l)
    SSH_CNT=$(ss -tlnp 2>/dev/null | awk '/LISTEN/ && /:22($| )/' | wc -l)
    CONN_CNT=$(ss -t state established 2>/dev/null | tail -n +2 | wc -l)
    echo -e "  HTTP  (80):   ${HTTP_CNT} proceso(s)"
    echo -e "  HTTPS (443):  ${HTTPS_CNT} proceso(s)"
    echo -e "  SSH   (22):   ${SSH_CNT} proceso(s)"
    echo -e "  Conexiones activas: ${CONN_CNT}"
    pause
}

