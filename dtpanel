}

_sign_install_java() {
    if command -v java &>/dev/null; then
        echo -e "  ${GREEN}✓ Java ya está instalado${NC}"
        return 0
    fi
    echo -e "  ${YELLOW}▶ Actualizando lista de paquetes...${NC}"
    if ! apt-get update -qq 2>&1 | tail -3; then
        echo -e "  ${RED}✗ apt-get update falló. Verificá conexión y repos.${NC}"
        return 1
    fi
    echo -e "  ${YELLOW}▶ Instalando openjdk-21-jdk-headless (JDK liviano)...${NC}"
    if apt-get install -y openjdk-21-jdk-headless 2>&1 | tail -10; then
        if command -v java &>/dev/null; then
            echo -e "  ${GREEN}✓ Java instalado: $(java -version 2>&1 | head -1)${NC}"
            return 0
        fi
    fi
    # Fallback: probar 17
    echo -e "  ${YELLOW}▶ Probando openjdk-17-jdk-headless...${NC}"
    apt-get install -y openjdk-17-jdk-headless 2>&1 | tail -5
    # Fallback: default-jdk
    if ! command -v java &>/dev/null; then
        echo -e "  ${YELLOW}▶ Probando default-jdk...${NC}"
        apt-get install -y default-jdk 2>&1 | tail -5
    fi
    if command -v java &>/dev/null; then
        echo -e "  ${GREEN}✓ Java instalado: $(java -version 2>&1 | head -1)${NC}"
    else
        echo -e "  ${RED}✗ No se pudo instalar Java. Probá manualmente:${NC}"
        echo -e "  ${DIM}    apt-get update && apt-get install -y openjdk-21-jdk-headless${NC}"
        return 1
    fi
}

_sign_gen_keystore() {
    if [ -f "$KEYSTORE" ]; then
        echo -e "  ${GREEN}✓ Keystore ya existe en ${KEYSTORE}${NC}"
        return 0
    fi
    KEYTOOL=$(command -v keytool 2>/dev/null || find /usr/lib/jvm -name "keytool" 2>/dev/null | head -1)
    if [ -z "$KEYTOOL" ]; then
        echo -e "  ${RED}✗ keytool no disponible. Instalá Java primero (opción 2).${NC}"
        return 1
    fi
    echo -e "  ${YELLOW}▶ Generando keystore con keytool...${NC}"
    "$KEYTOOL" -genkey -v -noprompt \
        -keystore "$KEYSTORE" -alias "$KEY_ALIAS" \
        -keyalg RSA -keysize 2048 -validity 10000 \
        -storepass "$KEY_PASS" -keypass "$KEY_PASS" \
        -dname "CN=DTunnel,OU=DTunnel,O=DTunnel,L=BuenosAires,S=BA,C=AR" 2>&1 | tail -5
    if [ -f "$KEYSTORE" ] && [ -s "$KEYSTORE" ]; then
        echo -e "  ${GREEN}✓ Keystore generado: ${KEYSTORE}${NC}"
    else
        echo -e "  ${RED}✗ Falló la generación del keystore${NC}"
        return 1
    fi
}

_sign_download_signer() {
    if [ -f "$UBER_SIGNER" ] && [ -s "$UBER_SIGNER" ]; then
        echo -e "  ${GREEN}✓ uber-apk-signer.jar ya descargado${NC}"
        return 0
    fi
    echo -e "  ${YELLOW}▶ Descargando uber-apk-signer.jar desde GitHub...${NC}"
    rm -f "$UBER_SIGNER" 2>/dev/null
    # Probar wget primero, luego curl
    if command -v wget &>/dev/null; then
        if wget --timeout=60 --tries=2 -O "$UBER_SIGNER" "$UBER_URL" 2>&1 | tail -5; then
            :
        fi
    fi
    if [ ! -s "$UBER_SIGNER" ] && command -v curl &>/dev/null; then
        echo -e "  ${YELLOW}▶ Reintentando con curl...${NC}"
        curl -L --max-time 60 -o "$UBER_SIGNER" "$UBER_URL" 2>&1 | tail -3
    fi
    if [ -f "$UBER_SIGNER" ] && [ -s "$UBER_SIGNER" ]; then
        SZ=$(stat -c%s "$UBER_SIGNER" 2>/dev/null)
        echo -e "  ${GREEN}✓ Descargado (${SZ} bytes)${NC}"
    else
        echo -e "  ${RED}✗ Falló la descarga${NC}"
        echo -e "  ${DIM}URL: ${UBER_URL}${NC}"
        rm -f "$UBER_SIGNER"
        return 1
    fi
}

_sign_fix_perms() {
    chown -R www-data:www-data "$SIGN_DIR" 2>/dev/null || true
    chmod 750 "$SIGN_DIR" 2>/dev/null || true
    [ -f "$KEYSTORE" ] && chmod 640 "$KEYSTORE" 2>/dev/null
    [ -f "$UBER_SIGNER" ] && chmod 644 "$UBER_SIGNER" 2>/dev/null
}

_sign_test_signing() {
    echo -e "  ${BOLD}▶ Test de firma con APK base...${NC}"

    if [ ! -f "$KEYSTORE" ]; then
        echo -e "  ${RED}✗ Falta keystore (opción 3)${NC}"
        return 1
    fi
    if ! command -v java &>/dev/null; then
        echo -e "  ${RED}✗ Falta Java (opción 2)${NC}"
        return 1
    fi

    # Buscar un APK base para probar
    BASE_APKS_DIR="$PANEL_DIR/panel/uploads/apk_bases"
    [ ! -d "$BASE_APKS_DIR" ] && BASE_APKS_DIR="$PANEL_DIR/uploads/apk_bases"
    TEST_APK=$(find "$BASE_APKS_DIR" -name "*.apk" 2>/dev/null | head -1)
    if [ -z "$TEST_APK" ]; then
        echo -e "  ${YELLOW}⚠ No hay APKs base en $BASE_APKS_DIR para probar${NC}"
        return 1
    fi
    echo -e "  ${DIM}Usando: $TEST_APK${NC}"

    TMPDIR=$(mktemp -d)
    cp "$TEST_APK" "$TMPDIR/test.apk"

    if [ -f "$UBER_SIGNER" ]; then
        echo -e "  ${YELLOW}▶ Firmando con uber-apk-signer (V1+V2+V3)...${NC}"
        java -jar "$UBER_SIGNER" \
            --apks "$TMPDIR/test.apk" \
            --out "$TMPDIR" \
            --ks "$KEYSTORE" \
            --ksAlias "$KEY_ALIAS" \
            --ksPass "$KEY_PASS" \
            --ksKeyPass "$KEY_PASS" \
            --allowResign --overwrite 2>&1 | tail -10
        SIGNED=$(find "$TMPDIR" -name "*signed*.apk" 2>/dev/null | head -1)
        [ -z "$SIGNED" ] && SIGNED="$TMPDIR/test.apk"
        if [ -f "$SIGNED" ] && [ -s "$SIGNED" ]; then
            SZ=$(stat -c%s "$SIGNED")
            echo -e "  ${GREEN}✓ APK firmado correctamente: ${SZ} bytes${NC}"
        else
            echo -e "  ${RED}✗ uber-apk-signer falló${NC}"
        fi
    elif command -v jarsigner &>/dev/null; then
        echo -e "  ${YELLOW}▶ Firmando con jarsigner V1 (fallback)...${NC}"
        jarsigner -sigalg SHA256withRSA -digestalg SHA-256 \
            -keystore "$KEYSTORE" \
            -storepass "$KEY_PASS" -keypass "$KEY_PASS" \
            "$TMPDIR/test.apk" "$KEY_ALIAS" 2>&1 | tail -5 \
