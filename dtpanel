try: users=json.load(open(DB_USERS));cfg=json.load(open(CFG_FILE))
except Exception as e: log(f"Error config: {e}");exit(1)
dias_antes=int(cfg.get('notify_days',3));smtp_host=cfg.get('smtp_host','smtp.gmail.com')
smtp_port=int(cfg.get('smtp_port',587));smtp_user=cfg.get('smtp_user','');smtp_pass=cfg.get('smtp_pass','')
from_name=cfg.get('from_name','By Elnene Panel WEB2');admin_rec=cfg.get('admin_recipients','')
contact_wa=cfg.get('contact_wa','No disponible');contact_tg=cfg.get('contact_tg','No disponible')
precio=cfg.get('precio_renovacion','Consulta con el admin');panel_url=cfg.get('panel_url','http://tu-panel.com')
tpl_subj=cfg.get('tpl_subject','Aviso: Tu acceso vence en {dias} dias')
tpl_body=cfg.get('tpl_body','Tu acceso vence el {fecha}.')
now=datetime.now();target=(now+timedelta(days=dias_antes)).strftime('%Y-%m-%d')
to_notify=[u for u in users if not u.get('role')=='admin' and not u.get('is_blocked')
           and u.get('expires_at','') and '2099' not in u.get('expires_at','')
           and u.get('expires_at','')[:10]==target]
if not to_notify: log(f"Sin usuarios a notificar (target:{target})");exit(0)
log(f"Notificando {len(to_notify)} usuario(s) que vencen el {target}")
try: server=smtplib.SMTP(smtp_host,smtp_port,timeout=15);server.starttls();server.login(smtp_user,smtp_pass)
except Exception as e: log(f"Error SMTP: {e}");exit(1)
for u in to_notify:
    nombre=u.get('username','Cliente');email=u.get('email','');fecha=u.get('expires_at','')[:10]
    if not email: continue
    subj=tpl_subj.format(nombre=nombre,email=email,fecha=fecha,dias=dias_antes,wa=contact_wa,tg=contact_tg,precio=precio,url=panel_url)
    body=tpl_body.format(nombre=nombre,email=email,fecha=fecha,dias=dias_antes,wa=contact_wa,tg=contact_tg,precio=precio,url=panel_url)
    try:
        msg=MIMEMultipart();msg['From']=f"{from_name} <{smtp_user}>";msg['To']=email;msg['Subject']=subj
        if admin_rec: msg['Bcc']=admin_rec
        msg.attach(MIMEText(body,'plain','utf-8'));server.send_message(msg);log(f"OK -> {nombre} <{email}>")
    except Exception as e: log(f"Error -> {email}: {e}")
server.quit()
NOTIFYEOF
        chmod +x /usr/local/bin/dtpanel-notify
        (crontab -l 2>/dev/null | grep -v "dtpanel-notify"; echo "0 8 * * * /usr/local/bin/dtpanel-notify") | crontab -
        _email_cfg_set "cron_enabled" "1"
        echo -e "\n  ${GREEN}Envio automatico activado (todos los dias a las 8:00 AM)${NC}"
        echo -e "  ${CYAN}  Script: /usr/local/bin/dtpanel-notify${NC}"
        echo -e "  ${CYAN}  Log:    /var/log/dtpanel-notify.log${NC}"; sleep 3
    fi
}

# ── [20] Gestionar APK base ───────────────────────────────────
do_upload_apk_base() {
    title
    echo -e "  ${BOLD}Gestionar APK base${NC}\n"
    APK_DIR="$PANEL_DIR/apk_base"
    mkdir -p "$APK_DIR"
    chown www-data:www-data "$APK_DIR" 2>/dev/null
    chmod 775 "$APK_DIR" 2>/dev/null

    # Mostrar bases ya cargadas
    echo -e "  ${BOLD}Bases en el panel:${NC}"
    BASES=($(ls "$APK_DIR"/*.apk 2>/dev/null))
    if [ ${#BASES[@]} -eq 0 ]; then
        echo -e "  ${YELLOW}  (ninguna base cargada aun)${NC}"
    else
        for f in "${BASES[@]}"; do
            SIZE=$(du -sh "$f" 2>/dev/null | cut -f1)
            echo -e "  ${GREEN}✓${NC} $(basename $f)  ${CYAN}(${SIZE})${NC}"
        done
    fi

    echo ""
    echo -e "  ${GREEN}[1]${NC} Seleccionar APK detectada en el servidor"
    echo -e "  ${GREEN}[2]${NC} Ingresar ruta manualmente"
    echo -e "  ${GREEN}[3]${NC} Eliminar una APK base"
    echo -e "  ${NC}[0]${NC} Volver"
    echo -ne "\n  Opcion: "; read AOPT

    case $AOPT in
        1)
            # Buscar APKs en ubicaciones comunes
            echo -e "\n  ${YELLOW}Buscando APKs en el servidor...${NC}\n"
            mapfile -t FOUND_APKS < <(find /root /home /tmp /var/www /opt -maxdepth 3 -name "*.apk" 2>/dev/null | sort)

            if [ ${#FOUND_APKS[@]} -eq 0 ]; then
                echo -e "  ${RED}No se encontraron archivos .apk en /root, /home, /tmp, /opt${NC}"
                echo -e "  ${YELLOW}Subí el APK al servidor primero (ej: scp archivo.apk root@IP:/root/)${NC}"
                sleep 3; return
            fi

            echo -e "  ${BOLD}APKs encontradas:${NC}"
            for i in "${!FOUND_APKS[@]}"; do
                SIZE=$(du -sh "${FOUND_APKS[$i]}" 2>/dev/null | cut -f1)
                NAME=$(basename "${FOUND_APKS[$i]}")
                echo -e "  ${GREEN}[$((i+1))]${NC} ${NAME}  ${CYAN}(${SIZE})${NC}"
                echo -e "       ${YELLOW}${FOUND_APKS[$i]}${NC}"
            done
            echo -e "  ${NC}[0]${NC} Cancelar"
            echo -ne "\n  Elegí el número: "; read NSEL
            [ "$NSEL" = "0" ] || [ -z "$NSEL" ] && return
            [[ ! "$NSEL" =~ ^[0-9]+$ ]] && echo -e "  ${RED}Número inválido${NC}" && sleep 2 && return
            APKPATH="${FOUND_APKS[$((NSEL-1))]}"
            [ -z "$APKPATH" ] || [ ! -f "$APKPATH" ] && echo -e "  ${RED}Número inválido${NC}" && sleep 2 && return
            APKNAME=$(basename "$APKPATH")
            cp "$APKPATH" "$APK_DIR/$APKNAME" \
                && chmod 644 "$APK_DIR/$APKNAME" \
                && echo -e "\n  ${GREEN}✓ APK base copiada: $APKNAME${NC}" \
                || echo -e "  ${RED}Error al copiar${NC}"
            sleep 3;;
        2)
            echo -e "\n  ${YELLOW}Ingresá la ruta COMPLETA del .apk:${NC}"
            echo -e "  (Ej: /root/ElNene_full_v4.5.12.apk)\n"
            echo -ne "  Ruta del archivo: "; read APKPATH
            [ -z "$APKPATH" ] && return
            [ ! -f "$APKPATH" ] && echo -e "  ${RED}Archivo no encontrado: $APKPATH${NC}" && sleep 3 && return
            [[ "$APKPATH" != *.apk ]] && echo -e "  ${RED}El archivo debe ser .apk${NC}" && sleep 2 && return
            APKNAME=$(basename "$APKPATH")
            cp "$APKPATH" "$APK_DIR/$APKNAME" \
                && chmod 644 "$APK_DIR/$APKNAME" \
                && echo -e "  ${GREEN}✓ APK base copiada: $APKNAME${NC}" \
                || echo -e "  ${RED}Error al copiar${NC}"
            sleep 3;;
        3)
            BASES_LIST=($(ls "$APK_DIR"/*.apk 2>/dev/null | xargs -I{} basename {} 2>/dev/null))
            if [ ${#BASES_LIST[@]} -eq 0 ]; then
                echo -e "  ${YELLOW}No hay bases para eliminar${NC}"; sleep 2; return
            fi
            echo -e "\n  Seleccioná el número a eliminar (0=cancelar):"
            for i in "${!BASES_LIST[@]}"; do
                echo -e "  ${GREEN}[$((i+1))]${NC} ${BASES_LIST[$i]}"
            done
            echo -ne "\n  N: "; read NDEL
            [ "$NDEL" = "0" ] || [ -z "$NDEL" ] && return
            FNAME="${BASES_LIST[$((NDEL-1))]}"
            [ -z "$FNAME" ] && echo -e "  ${RED}Número inválido${NC}" && sleep 2 && return
            rm -f "$APK_DIR/$FNAME" \
                && echo -e "  ${GREEN}✓ Eliminada: $FNAME${NC}" \
                || echo -e "  ${RED}Error${NC}"
            sleep 2;;
        0) return;;
        *) echo -e "  ${RED}Opción inválida${NC}"; sleep 1;;
    esac
}

