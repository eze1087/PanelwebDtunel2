# ── [7] Buscar ────────────────────────────────────────────────
do_search_user() {
    title
    echo -e "  ${BOLD}Buscar cliente${NC}\n"
    echo -ne "  Nombre o email: "
    read TERM
    [ -z "$TERM" ] && return
    [ ! -f "$DB_USERS" ] && echo -e "  ${RED}Sin usuarios${NC}" && pause && return
    echo ""
    python3 -c "
import json
from datetime import datetime
term='$(echo $TERM | tr '[:upper:]' '[:lower:]')'
users=json.load(open('$DB_USERS'))
found=[u for u in users if term in u.get('email','').lower() or term in u.get('username','').lower()]
if not found: print('  Sin resultados')
else:
    now=datetime.now()
    for u in found:
        exp=u.get('expires_at','---')
        bl=u.get('is_blocked',False)
        role=u.get('role','user')
        if '2099' in exp: status='Admin/Ilimitado'
        elif bl: status='BLOQUEADO'
        else:
            try:
                diff=(datetime.strptime(exp[:19],'%Y-%m-%d %H:%M:%S')-now).days
                status='Vencido' if diff<0 else f'{diff} días restantes'
            except: status='?'
        print(f\"  Usuario: {u.get('username','?')}\")
        print(f\"  Email:   {u.get('email','?')}\")
        print(f\"  Vence:   {exp[:10] if exp else '---'} | Estado: {status} | Rol: {role}\")
        print('  ' + '-'*55)
" 2>/dev/null
    pause
}

