do_status() {
    title
    echo -e "  ${BOLD}Estado del Panel${NC}\n"
    echo -e "  Apache:     $(systemctl is-active apache2 2>/dev/null)"
    echo -e "  PHP:        $(php -r 'echo PHP_VERSION;' 2>/dev/null)"
    echo -e "  IP pública: ${GREEN}${SERVER_IP}${NC}"
    echo -e "  Panel web:  ${GREEN}http://${SERVER_IP}${NC}"
    echo -e "  .htaccess:  $([ -f $PANEL_DIR/.htaccess ] && echo "${GREEN}OK${NC}" || echo "${RED}FALTA${NC}")"
    echo ""
    if [ -f "$DB_USERS" ]; then
        python3 -c "
import json
from datetime import datetime
try:
    users = json.load(open('$DB_USERS'))
    now = datetime.now()
    total = len(users)
    admins = sum(1 for u in users if u.get('role')=='admin')
    blocked = sum(1 for u in users if u.get('is_blocked', False))
    vencidos = 0
    for u in users:
        exp = u.get('expires_at','')
        if exp and '2099' not in exp:
