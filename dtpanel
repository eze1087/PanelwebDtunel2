        [ -f /tmp/db_bk.sqlite ] && cp /tmp/db_bk.sqlite "$DB_SQLITE"
        # .htaccess con limites PHP para APKs grandes
        cat > "$PANEL_DIR/.htaccess" << 'HTEOF'
