            except: pass
    print(f'  Clientes registrados: {total}')
    print(f'  Administradores:      {admins}')
    print(f'  Activos:              {total-blocked-vencidos}')
    print(f'  Por vencer (< 5d):    ', end='')
    close=sum(1 for u in users if not u.get('is_blocked') and u.get('expires_at','') and '2099' not in u.get('expires_at','') and 0 <= (datetime.strptime(u['expires_at'][:19],'%Y-%m-%d %H:%M:%S')-now).days < 5 if u.get('expires_at'))
    print(close)
    print(f'  Vencidos:             {vencidos}')
    print(f'  Bloqueados:           {blocked}')
except Exception as e:
    print(f'  Error: {e}')
" 2>/dev/null
    else
        echo -e "  ${YELLOW}Sin usuarios registrados aún${NC}"
