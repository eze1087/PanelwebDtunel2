# ── [22] SSL / HTTPS con Let's Encrypt ───────────────────────
do_ssl() {
    title
    echo -e "  ${BOLD}🔒 Instalar HTTPS — Let's Encrypt${NC}\n"
    echo -e "  ${DIM}Instala un certificado SSL gratuito para tu dominio.${NC}"
    echo -e "  ${CYAN}Requisito:${NC} el dominio debe apuntar a la IP ${GREEN}${SERVER_IP}${NC}"
    echo -e "  ${CYAN}Puerto 80 y 443${NC} deben estar abiertos en el firewall.\n"

    # Mostrar cert existente si hay
    if command -v certbot &>/dev/null; then
        local EXISTING=$(certbot certificates 2>/dev/null | grep "Domains:" | awk '{print $2}')
        if [ -n "$EXISTING" ]; then
            echo -e "  ${GREEN}Certificado activo:${NC} ${CYAN}${EXISTING}${NC}"
            echo -e "  ${DIM}Para renovar manualmente: certbot renew${NC}\n"
            echo -e "  ${GREEN}[1]${NC} Instalar/renovar certificado"
            echo -e "  ${GREEN}[2]${NC} Revocar y eliminar certificado"
            echo -e "  ${NC}[0]${NC} Volver"
            echo -ne "\n  Opción: "; read SSLOPT
            case $SSLOPT in
                2)
                    echo -ne "\n  ${RED}¿Seguro que querés revocar ${EXISTING}? (s/N): ${NC}"; read CONFIRM
                    [[ "$CONFIRM" != "s" && "$CONFIRM" != "S" ]] && return
                    certbot delete --cert-name "$EXISTING" --non-interactive 2>&1
                    echo -e "  ${GREEN}Certificado eliminado.${NC}"; pause; return;;
                0|"") return;;
            esac
        fi
    fi

    echo -ne "\n  Dominio (ej: panelweb2.elnene.site): "
    read SSL_DOMAIN
    [ -z "$SSL_DOMAIN" ] && echo -e "  ${YELLOW}Cancelado${NC}" && sleep 1 && return

    echo -ne "  Email para avisos del certificado: "
    read SSL_EMAIL
    [ -z "$SSL_EMAIL" ] && SSL_EMAIL="admin@${SSL_DOMAIN}"

    # Verificar que el dominio resuelve a esta IP
    echo -e "\n  ${YELLOW}Verificando DNS de ${SSL_DOMAIN}...${NC}"
    RESOLVED_IP=$(dig +short "$SSL_DOMAIN" 2>/dev/null | head -1)
    [ -z "$RESOLVED_IP" ] && RESOLVED_IP=$(nslookup "$SSL_DOMAIN" 2>/dev/null | grep "Address:" | tail -1 | awk '{print $2}')
    if [ -n "$RESOLVED_IP" ] && [ "$RESOLVED_IP" != "$SERVER_IP" ]; then
        echo -e "  ${YELLOW}⚠ El dominio resuelve a ${CYAN}${RESOLVED_IP}${NC}, no a ${GREEN}${SERVER_IP}${NC}"
        echo -e "  ${DIM}Si acabás de configurar el DNS, esperá hasta 10 min y volvé a intentar.${NC}"
        echo -ne "  ¿Continuar de todas formas? (s/N): "; read DNSOK
        [[ "$DNSOK" != "s" && "$DNSOK" != "S" ]] && return
    fi

    echo -e "\n  ${YELLOW}[1/3] Instalando certbot...${NC}"
    apt-get install -y certbot python3-certbot-apache -qq 2>&1 | grep -E "^(Get|Inst|Error|E:)" || true

    if ! command -v certbot &>/dev/null; then
        echo -e "  ${RED}Error al instalar certbot. Ejecutá manualmente:${NC}"
        echo -e "  ${DIM}apt install -y certbot python3-certbot-apache${NC}"
        pause; return
    fi

    echo -e "  ${YELLOW}[2/3] Solicitando certificado para ${CYAN}${SSL_DOMAIN}${NC}..."
    certbot --apache -d "$SSL_DOMAIN" --non-interactive --agree-tos -m "$SSL_EMAIL" 2>&1
    SSL_RESULT=$?

    echo -e "\n  ${YELLOW}[3/3] Reiniciando Apache...${NC}"
    systemctl reload apache2 2>/dev/null
    systemctl restart apache2 2>/dev/null

    echo ""
    if [ $SSL_RESULT -eq 0 ]; then
        echo -e "  ${BGREEN}✅ HTTPS instalado correctamente${NC}"
        echo -e "  ${GREEN}Tu panel ahora es accesible en: https://${SSL_DOMAIN}${NC}"
        echo -e "  ${DIM}Renovación automática: cada 90 días vía cron (systemd timer).${NC}"
        echo -e "  ${DIM}Para verificar: certbot certificates${NC}"
    else
        echo -e "  ${BRED}❌ Error al obtener el certificado${NC}"
        echo -e "\n  ${YELLOW}Verificá que:${NC}"
        echo -e "    • ${CYAN}${SSL_DOMAIN}${NC} apunta a ${CYAN}${SERVER_IP}${NC} (DNS propagado)"
        echo -e "    • El puerto 80 está accesible desde internet"
        echo -e "    • No hay otro proceso usando el puerto 80"
        echo -e "\n  ${DIM}Para debug: certbot certonly --standalone -d ${SSL_DOMAIN}${NC}"
    fi
    pause
}

