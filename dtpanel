# ── [17] Desinstalar ──────────────────────────────────────────
do_uninstall() {
    title
    echo -e "  ${BRED}${BOLD}DESINSTALAR PANEL${NC}"
    echo -e "  ${RED}Esta acción eliminará todos los archivos del panel.${NC}"
    echo -e "  ${YELLOW}Se creará un backup antes de desinstalar.${NC}"
    echo ""
    echo -ne "  ${RED}Escribí ${BOLD}SI${NC}${RED} para confirmar (o Enter para cancelar): ${NC}"
    read CONF
    if [[ "$CONF" == "SI" ]]; then
        echo ""
        echo -e "  ${YELLOW}[1/4] Creando backup de seguridad...${NC}"
        mkdir -p "$BACKUP_DIR"
        BKNAME="$BACKUP_DIR/backup-antes-desinst-$(date +%Y%m%d_%H%M%S).tar.gz"
        tar -czf "$BKNAME" -C "$PANEL_DIR" . 2>/dev/null \
            && echo -e "  ${GREEN}✓ Backup guardado: $BKNAME${NC}" \
            || echo -e "  ${YELLOW}⚠ Backup falló, continuando...${NC}"

        echo -e "  ${YELLOW}[2/4] Eliminando archivos del panel...${NC}"
        rm -rf "${PANEL_DIR:?}"/* "${PANEL_DIR:?}"/.[!.]* 2>/dev/null
        REMAINING=$(find "$PANEL_DIR" -mindepth 1 2>/dev/null | wc -l)
        if [ "$REMAINING" -eq 0 ]; then
            echo -e "  ${GREEN}✓ Archivos eliminados${NC}"
        else
            echo -e "  ${YELLOW}⚠ Quedan $REMAINING items, forzando...${NC}"
            find "$PANEL_DIR" -mindepth 1 -depth -exec rm -rf {} + 2>/dev/null
            echo -e "  ${GREEN}✓ Limpieza forzada completada${NC}"
        fi

        echo -e "  ${YELLOW}[3/4] Eliminando comando 'panel'...${NC}"
        rm -f /usr/local/bin/panel 2>/dev/null \
            && echo -e "  ${GREEN}✓ Comando eliminado${NC}" \
            || echo -e "  ${YELLOW}⚠ No se encontró el comando${NC}"

        echo -e "  ${YELLOW}[4/4] Deteniendo Apache...${NC}"
        systemctl stop apache2 2>/dev/null \
            && echo -e "  ${GREEN}✓ Apache detenido${NC}" \
            || echo -e "  ${YELLOW}⚠ Apache no estaba activo${NC}"

        echo ""
        echo -e "${BCYAN}──────────────────────────────────────────────────────────────${NC}"
        echo -e "  ${GREEN}${BOLD}Panel desinstalado correctamente${NC}"
        [ -f "$BKNAME" ] && echo -e "  ${CYAN}Backup en:${NC} $BKNAME"
        echo -e "${BCYAN}──────────────────────────────────────────────────────────────${NC}"
        echo ""
        exit 0
