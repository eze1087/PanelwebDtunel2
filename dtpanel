}

# ── [2] Reiniciar ─────────────────────────────────────────────
do_restart() {
    echo -e "\n${YELLOW}Reiniciando Apache...${NC}"
    # Intentar restart normal
    if systemctl restart apache2 2>/dev/null; then
        echo -e "  ${GREEN}✓ Apache reiniciado correctamente${NC}"
    else
        echo -e "  ${YELLOW}Fallo en restart — verificando puerto 80...${NC}"
        # Buscar PID del proceso que ocupa el puerto 80
        local PID80=$(ss -tlnp 'sport = :80' 2>/dev/null \
            | grep LISTEN | grep -oP 'pid=\K[0-9]+' | head -1)
        if [ -n "$PID80" ]; then
            local PROC80=$(ps -p "$PID80" -o comm= 2>/dev/null || echo "desconocido")
            echo -e "  Puerto 80 ocupado por: ${RED}${PROC80}${NC} (PID: ${PID80})"
            if [[ "$PROC80" != *apache* ]] && [[ "$PROC80" != *httpd* ]]; then
                echo -e "  ${YELLOW}Liberando puerto 80...${NC}"
                kill -9 "$PID80" 2>/dev/null
                sleep 1
            fi
        fi
        # Detener completamente y volver a iniciar
        systemctl stop apache2 2>/dev/null
        sleep 1
        systemctl start apache2 2>/dev/null \
            && echo -e "  ${GREEN}✓ Apache iniciado${NC}" \
            || {
                echo -e "  ${RED}✗ No se pudo iniciar Apache${NC}"
                echo -e "  ${DIM}Ver detalles: journalctl -u apache2 -n 15 --no-pager${NC}"
            }
    fi
    sleep 2
}

