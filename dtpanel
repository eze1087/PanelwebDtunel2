# ── Corregir límites PHP y sincronización ─────────────────────
do_fix_php_limits() {
    title
    echo -e "  ${BOLD}Corregir límites PHP + Sincronización de app${NC}\n"
    echo -e "  Upload actual: ${YELLOW}$(php -r 'echo ini_get("upload_max_filesize");' 2>/dev/null)${NC}\n"
    echo -e "  ${YELLOW}[1/3] Aplicando límites en PHP-FPM y php.ini...${NC}"

    CHANGED=0
    for PHP_INI in /etc/php/*/fpm/php.ini /etc/php/*/apache2/php.ini /etc/php/*/cli/php.ini; do
        if [ -f "$PHP_INI" ]; then
            sed -i 's/^upload_max_filesize = .*/upload_max_filesize = 200M/' "$PHP_INI"
            sed -i 's/^post_max_size = .*/post_max_size = 210M/' "$PHP_INI"
            sed -i 's/^memory_limit = .*/memory_limit = 512M/' "$PHP_INI"
            sed -i 's/^max_execution_time = .*/max_execution_time = 300/' "$PHP_INI"
            echo -e "  ${GREEN}✓ $PHP_INI${NC}"; CHANGED=1
        fi
    done
    for POOL in /etc/php/*/fpm/pool.d/www.conf; do
        if [ -f "$POOL" ]; then
            grep -q "php_admin_value\[upload_max_filesize\]" "$POOL" \
                && sed -i 's/php_admin_value\[upload_max_filesize\].*/php_admin_value[upload_max_filesize] = 200M/' "$POOL" \
                || echo "php_admin_value[upload_max_filesize] = 200M" >> "$POOL"
            grep -q "php_admin_value\[post_max_size\]" "$POOL" \
                && sed -i 's/php_admin_value\[post_max_size\].*/php_admin_value[post_max_size] = 210M/' "$POOL" \
                || echo "php_admin_value[post_max_size] = 210M" >> "$POOL"
            grep -q "php_admin_value\[memory_limit\]" "$POOL" \
                && sed -i 's/php_admin_value\[memory_limit\].*/php_admin_value[memory_limit] = 512M/' "$POOL" \
                || echo "php_admin_value[memory_limit] = 512M" >> "$POOL"
            echo -e "  ${GREEN}✓ Pool FPM: $POOL${NC}"; CHANGED=1
        fi
    done
    cat > "$PANEL_DIR/.user.ini" << 'PHPINI'
upload_max_filesize = 200M
post_max_size = 210M
max_execution_time = 300
max_input_time = 300
memory_limit = 512M
PHPINI
    chmod 644 "$PANEL_DIR/.user.ini"
    echo -e "  ${GREEN}✓ .user.ini actualizado${NC}"

    echo ""
    echo -e "  ${YELLOW}[2/3] Corrigiendo campo 'status' en usuarios (necesario para sincronización)...${NC}"
    python3 -c "
import json
path='$DB_USERS'
try:
    users=json.load(open(path))
    changed=0
    for u in users:
        if 'status' not in u or u['status'] not in ['active','Active','ACTIVE']:
            u['status']='active'
            changed+=1
        # Asegurar UUID real (no 'admin-master')
        if u.get('uuid','') in ['admin-master','','---']:
            import uuid as uuidlib
            u['uuid']=str(uuidlib.uuid4())
            changed+=1
    if changed:
        open(path,'w').write(json.dumps(users,indent=4,ensure_ascii=False))
        print(f'  Corregidos {changed} campo(s)')
    else:
        print('  Todos los usuarios ya tienen status correcto')
except Exception as e:
    print('  Error: '+str(e))
" 2>/dev/null

    echo ""
    echo -e "  ${YELLOW}[3/3] Reiniciando servicios...${NC}"
    for FPM_SVC in $(systemctl list-units --type=service --state=active 2>/dev/null | grep -oP 'php\S*fpm\S*\.service' | head -3); do
        systemctl restart "$FPM_SVC" 2>/dev/null && echo -e "  ${GREEN}✓ $FPM_SVC${NC}"
    done
    systemctl restart apache2 2>/dev/null && echo -e "  ${GREEN}✓ Apache reiniciado${NC}"

    echo ""
    echo -e "  ${BOLD}Nuevo límite PHP:${NC} ${GREEN}$(php -r 'echo ini_get("upload_max_filesize");' 2>/dev/null)${NC}"
    echo -e "  ${GREEN}✓ Listo — ahora podés subir APKs desde el panel web y las apps se sincronizarán${NC}"
    sleep 3
}

