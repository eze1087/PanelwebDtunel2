    export DTDB_USERS="$DB_USERS"
    export DTDB_TXNS="$PANEL_DIR/db/transacoes.json"
    python3 << 'PYSTATS'
import json,os
from datetime import datetime,timedelta
from collections import Counter
DB_USERS=os.environ.get('DTDB_USERS','/var/www/html/db/usuarios.json')
DB_TXNS=os.environ.get('DTDB_TXNS','/var/www/html/db/transacoes.json')
R='\033[0;31m';G='\033[0;32m';Y='\033[1;33m';C='\033[0;36m';B='\033[1m';N='\033[0m'
now=datetime.now();today=now.date()
sem_ini=today-timedelta(days=today.weekday())
mes_ini=today.replace(day=1)
mes_ant=(mes_ini-timedelta(days=1)).replace(day=1)
try:    users=json.load(open(DB_USERS))
except: users=[]
try:    txns=json.load(open(DB_TXNS))
except: txns=[]
total=len(users);admins=sum(1 for u in users if u.get('role')=='admin')
blocked=sum(1 for u in users if u.get('is_blocked',False))
ilimit=sum(1 for u in users if '2099' in str(u.get('expires_at','')))
vencidos=por_vencer=activos=0
for u in users:
    if u.get('role')=='admin': continue
    exp=u.get('expires_at','')
    if not exp: continue
    try:
        diff=(datetime.strptime(exp[:19],'%Y-%m-%d %H:%M:%S')-now).days
        if diff<0: vencidos+=1
        elif diff<5: por_vencer+=1
        else: activos+=1
    except: pass
def pd(s):
    if not s: return None
    try:
        if isinstance(s,(int,float)): return datetime.fromtimestamp(s).date()
        return datetime.strptime(str(s)[:19],'%Y-%m-%d %H:%M:%S').date()
    except: return None
reg_sem=reg_mes=reg_ant=0
for u in users:
    if u.get('role')=='admin': continue
    d=pd(u.get('created_at',''))
    if d is None: continue
    if d>=sem_ini: reg_sem+=1
    if d>=mes_ini: reg_mes+=1
    if mes_ant<=d<mes_ini: reg_ant+=1
pagados=[t for t in txns if t.get('status')=='pago']
pend=[t for t in txns if t.get('status')=='pendente']
is_sem=im=ia=it=0.0;cs=cm=ca=0
for t in pagados:
    p=float(t.get('price',0));d=pd(t.get('created_at',0));it+=p
    if d is None: continue
    if d>=sem_ini: is_sem+=p;cs+=1
    if d>=mes_ini: im+=p;cm+=1
    if mes_ant<=d<mes_ini: ia+=p;ca+=1
def crec(cur,prev):
    if prev==0: return f"{Y}N/D{N}"
    pct=(cur-prev)/prev*100
    return f"{G}+{pct:.1f}%{N}" if pct>=0 else f"{R}{pct:.1f}%{N}"
hist=[]
for i in range(5,-1,-1):
    ref=mes_ini
    for _ in range(i): ref=(ref-timedelta(days=1)).replace(day=1)
    sig=(ref.replace(day=28)+timedelta(days=4)).replace(day=1)
    lbl=ref.strftime('%b/%y').capitalize()
    hi=sum(float(t.get('price',0)) for t in pagados if (d:=pd(t.get('created_at',0))) and d is not None and ref<=d<sig)
    hr=sum(1 for u in users if u.get('role')!='admin' and (d:=pd(u.get('created_at',''))) and d is not None and ref<=d<sig)
    hist.append((lbl,hi,hr))
planes=Counter(t.get('plan_name','Desconocido') for t in pagados if t.get('plan_name'))
def sep(t=''):
    if t: print(f"  {B}--- {t} "+"─"*(40-len(t))+N)
    else: print("  "+"─"*46)
sep('CLIENTES')
print(f"  Total registrados:      {B}{total}{N}")
print(f"  Activos:                {G}{activos}{N}")
print(f"  Ilimitados/Admin:       {C}{ilimit+admins}{N}")
print(f"  Por vencer (< 5 dias):  {Y}{por_vencer}{N}")
print(f"  Vencidos:               {R}{vencidos}{N}")
print(f"  Bloqueados:             {R}{blocked}{N}")
print()
sep('NUEVOS CLIENTES')
print(f"  Esta semana:            {G}{reg_sem}{N}  registrados")
print(f"  Este mes:               {G}{reg_mes}{N}  registrados")
print(f"  Mes anterior:           {C}{reg_ant}{N}  registrados")
print(f"  Crecimiento mensual:    {crec(reg_mes,reg_ant)}")
print()
sep('INGRESOS')
print(f"  Esta semana:            {G}$ {is_sem:.2f}{N}  ({cs} ventas)")
print(f"  Este mes:               {G}$ {im:.2f}{N}  ({cm} ventas)")
print(f"  Mes anterior:           {C}$ {ia:.2f}{N}  ({ca} ventas)")
print(f"  Crecimiento:            {crec(im,ia)}")
print(f"  {B}Total acumulado:        {G}$ {it:.2f}{N}")
print(f"  Pendientes de cobro:    {Y}{len(pend)} transacciones{N}")
print()
sep('HISTORICO 6 MESES')
print(f"  {'MES':<10} {'INGRESOS':>10}   {'CLIENTES':>8}   EVOLUCION")
print(f"  {'-'*10} {'-'*10}   {'-'*8}   {'-'*20}")
mx=max((h[1] for h in hist),default=1) or 1
for lbl,hi,hr in hist:
    bl=int(hi/mx*18) if hi>0 else 0
    bar=G+'#'*bl+N+'.'*(18-bl)
    print(f"  {lbl:<10} {G}${hi:>9.2f}{N}   {C}{hr:>5} cl{N}   {bar}")
print()
if planes:
    sep('PLANES MAS VENDIDOS')
    tv=sum(planes.values())
    for plan,cant in planes.most_common(5):
        pct=cant/tv*100;bl=int(pct/100*15)
        print(f"  {plan[:28]:<28} {G}{cant:>3}{N} ventas  {pct:>5.1f}%  {G}{'#'*bl}{N}")
sep()
PYSTATS
    pause
}

