PANEL_VERSION="v1.0.54"
PANEL_COMMIT="configs-rawarray-signing"
PANEL_DATE="2026-05-10"

PANEL_DIR="/var/www/html"
BACKUP_DIR="/var/backups/dtpanel"
DB_USERS="$PANEL_DIR/db/usuarios.json"
DB_SQLITE="$PANEL_DIR/database/database.sqlite"
ADMIN_EMAIL_FILE="$PANEL_DIR/db/.admin_email"
EMAIL_CFG="$PANEL_DIR/db/.email_config.json"

RED='\033[0;31m';    GREEN='\033[0;32m';  YELLOW='\033[1;33m'
CYAN='\033[0;36m';  BOLD='\033[1m';     NC='\033[0m'
BLUE='\033[0;34m';  PURPLE='\033[0;35m'; WHITE='\033[1;37m'
BGREEN='\033[1;32m'; BRED='\033[1;31m'; BYELLOW='\033[1;33m'
BCYAN='\033[1;36m';  BBLUE='\033[1;34m'; DIM='\033[2m'

get_ipv4() {
    IP=$(curl -4 -s --max-time 5 ifconfig.me 2>/dev/null)
    [ -z "$IP" ] && IP=$(curl -4 -s --max-time 5 icanhazip.com 2>/dev/null)
    [ -z "$IP" ] && IP=$(ip -4 addr show scope global | grep inet | awk '{print $2}' | cut -d/ -f1 | head -1)
    [ -z "$IP" ] && IP=$(hostname -I | tr ' ' '\n' | grep -v ':' | head -1)
    echo "$IP"
}
SERVER_IP=$(get_ipv4)

pause() { echo ""; read -p "  Presioná ENTER para continuar..."; }

htaccess_check() {
    if [ ! -f "$PANEL_DIR/.htaccess" ]; then
        cat > "$PANEL_DIR/.htaccess" << 'HTEOF'
Options -Indexes
RewriteEngine On
RewriteBase /
RewriteRule ^(pages|includes|database|api|db)/.*$ /404 [R=403,L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]

<IfModule mod_php.c>
    php_value memory_limit 1024M
    php_value max_execution_time 0
    php_value max_input_time 600
    php_value post_max_size 210M
    php_value upload_max_filesize 200M
</IfModule>
<IfModule mod_php8.c>
    php_value memory_limit 1024M
    php_value max_execution_time 0
    php_value max_input_time 600
    php_value post_max_size 210M
    php_value upload_max_filesize 200M
</IfModule>
<IfModule mod_php7.c>
    php_value memory_limit 1024M
    php_value max_execution_time 0
    php_value max_input_time 600
    php_value post_max_size 210M
    php_value upload_max_filesize 200M
</IfModule>
HTEOF
        chown www-data:www-data "$PANEL_DIR/.htaccess"
        chmod 644 "$PANEL_DIR/.htaccess"
        systemctl restart apache2 -q
    fi
}

title() {
    clear
    htaccess_check

    local DATE_NOW=$(date '+%d/%m/%Y %H:%M:%S')
    local SO=$(lsb_release -ds 2>/dev/null | tr -d '"' || echo "Linux")
    local ARCH=$(uname -m)
    local CPU_CORES=$(nproc 2>/dev/null || echo 1)
    local LOAD=$(uptime 2>/dev/null | awk -F'load average:' '{gsub(/^ /,"",$2); print $2}' || echo "—")
    local APACHE_STATUS=$(systemctl is-active apache2 2>/dev/null)
    local APACHE_TXT="ACTIVO"; local APACHE_COL=$BGREEN
    [ "$APACHE_STATUS" != "active" ] && { APACHE_TXT="INACTIVO"; APACHE_COL=$BRED; }
    local TOTAL_U=0
    [ -f "$DB_USERS" ] && TOTAL_U=$(python3 -c "import json; d=json.load(open('$DB_USERS')); print(len(d))" 2>/dev/null || echo 0)
    local DISK_USED=$(df -h / 2>/dev/null | awk 'NR==2{print $3}')
    local DISK_TOTAL=$(df -h / 2>/dev/null | awk 'NR==2{print $2}')
    local DISK_USE=$(df -h / 2>/dev/null | awk 'NR==2{print $5}')
    local DISK_FREE=$(df -h / 2>/dev/null | awk 'NR==2{print $4}')
    local RAM_USED=$(free -m 2>/dev/null | awk 'NR==2{print $3}')
    local RAM_TOTAL=$(free -m 2>/dev/null | awk 'NR==2{print $2}')
    local RAM_PCT=$(free -m 2>/dev/null | awk 'NR==2{printf "%.0f", $3/$2*100}')
    local RAM_FREE=$(free -m 2>/dev/null | awk 'NR==2{print $4}')
    # CPU uso instantáneo — método confiable en Ubuntu
    local CPU_USE=$(top -bn2 -d0.2 2>/dev/null | grep -i '%cpu\|Cpu(s)' | tail -1 \
        | awk '{for(i=1;i<=NF;i++){if($i~/^[0-9]+\.?[0-9]*$/ && $(i-1)~/us|ni|CPU/){printf "%d",$i;exit}}}' 2>/dev/null)
    [ -z "$CPU_USE" ] && CPU_USE="0"
    local LAST_BK=$(ls /var/backups/dtpanel/*.tar.gz 2>/dev/null | sort | tail -1 \
        | xargs -I{} stat -c "%y" {} 2>/dev/null | cut -c1-10 || echo "NO")
    [ -z "$LAST_BK" ] && LAST_BK="NO"
    local NET_DEV=$(ip route get 8.8.8.8 2>/dev/null | grep -oP 'dev \K\S+' | head -1)
    local NET_RX="0"; local NET_TX="0"
    if [ -n "$NET_DEV" ] && [ -f "/sys/class/net/${NET_DEV}/statistics/rx_bytes" ]; then
        local _rx=$(cat /sys/class/net/${NET_DEV}/statistics/rx_bytes 2>/dev/null || echo 0)
        local _tx=$(cat /sys/class/net/${NET_DEV}/statistics/tx_bytes 2>/dev/null || echo 0)
        NET_RX=$(awk "BEGIN{printf \"%.2f\", $_rx/1073741824}")
        NET_TX=$(awk "BEGIN{printf \"%.2f\", $_tx/1073741824}")
    fi
    local PANEL_URL="http://${SERVER_IP}"
    local SSL_TXT="${RED}NO${NC}"
    if command -v certbot &>/dev/null; then
        local SSL_DOM=$(certbot certificates 2>/dev/null | grep "Domains:" | head -1 | awk '{print $2}')
        [ -n "$SSL_DOM" ] && { PANEL_URL="https://${SSL_DOM}"; SSL_TXT="${GREEN}${SSL_DOM}${NC}"; }
    fi

    # ╔══════════════════════════════════════════════════════════╗  (inner=58)
    # Centrar version dinamicamente — sin emojis para alineacion perfecta
    local VER="${PANEL_VERSION}  *  commit: ${PANEL_COMMIT}  *  ${PANEL_DATE}"
    local VL=${#VER}
    local LP=$(( (58 - VL) / 2 ))
    local RP=$(( 58 - VL - LP ))

    echo -e "${BCYAN}╔══════════════════════════════════════════════════════════╗${NC}"
    echo -e "${BCYAN}║${NC}  ${BBLUE}══════════════════════════════════════════════════════${NC}  ${BCYAN}║${NC}"
    echo -e "${BCYAN}║${NC}               ${BGREEN}★${NC}  ${BRED}${BOLD}PANEL${NC} ${BYELLOW}${BOLD}WEB2${NC}  ${BCYAN}${BOLD}By El NeNe${NC}  ${BGREEN}★${NC}               ${BCYAN}║${NC}"
    echo -e "${BCYAN}║${NC}  ${BBLUE}══════════════════════════════════════════════════════${NC}  ${BCYAN}║${NC}"
    printf "${BCYAN}║${NC}${DIM}%${LP}s%s%${RP}s${NC}${BCYAN}║${NC}\n" "" "$VER" ""
    echo -e "${BCYAN}╚══════════════════════════════════════════════════════════╝${NC}"

    # ── SISTEMA ────────────────────────────────────────────────────
    echo -e "${BCYAN}──────────────────────────────────────────────────────────────${NC}"
    printf "  ${DIM}S.O  :${NC} %-30s${DIM}IP    :${NC} %s\n"    "${SO:0:28}" "$SERVER_IP"
    printf "  ${DIM}Arch :${NC} %-30s${DIM}Fecha :${NC} %s\n"    "$ARCH"        "$DATE_NOW"
    # ── PANEL ──────────────────────────────────────────────────────
    echo -e "${BCYAN}──────────────────────────────────────────────────────────────${NC}"
    printf "  Apache : ${APACHE_COL}%-10s${NC}  Usuarios: ${WHITE}%s${NC}   Backup: %s\n" \
        "$APACHE_TXT" "$TOTAL_U" "$LAST_BK"
    printf "  URL    : ${YELLOW}%-38s${NC}  SSL: ${SSL_TXT}\n" "$PANEL_URL"
    # ── RECURSOS ───────────────────────────────────────────────────
    echo -e "${BCYAN}──────────────────────────────────────────────────────────────${NC}"
    printf "  Disco  : ${BBLUE}%s / %s${NC} (%s)   libre: %s\n"           "$DISK_USED" "$DISK_TOTAL" "$DISK_USE" "$DISK_FREE"
    printf "  RAM    : ${BBLUE}%s / %s MB${NC} (%s%%)  libre: %s MB\n"    "$RAM_USED"  "$RAM_TOTAL"  "$RAM_PCT"  "$RAM_FREE"
    printf "  CPU    : ${BBLUE}%sc${NC}  uso: ${BBLUE}%s%%${NC}  load: %s\n" "$CPU_CORES" "$CPU_USE" "$LOAD"
    printf "  Red    : RX ${BBLUE}%s GB${NC}  |  TX ${BBLUE}%s GB${NC}  (desde boot)\n" "$NET_RX" "$NET_TX"
    echo -e "${BCYAN}──────────────────────────────────────────────────────────────${NC}"
    echo ""
}


