# ── [15] Restaurar ────────────────────────────────────────────
do_restore() {
    title
    echo -e "  ${BOLD}Backups disponibles${NC}\n"
    mkdir -p "$BACKUP_DIR"
    BACKUPS=($(ls -t "$BACKUP_DIR"/*.tar.gz 2>/dev/null))
    if [ ${#BACKUPS[@]} -eq 0 ]; then
        echo -e "  ${RED}No hay backups${NC}"; sleep 2; return
    fi
    for i in "${!BACKUPS[@]}"; do
        echo -e "  ${GREEN}[$((i+1))]${NC} $(basename ${BACKUPS[$i]}) — $(du -sh ${BACKUPS[$i]} | cut -f1)"
    done
    echo -ne "\n  Elegí número (0=cancelar): "
    read CHOICE
    [ "$CHOICE" = "0" ] && return
    SELECTED="${BACKUPS[$((CHOICE-1))]}"
    if [ -f "$SELECTED" ]; then
        echo -e "\n  ${YELLOW}Restaurando...${NC}"
        find "$PANEL_DIR" -mindepth 1 -delete 2>/dev/null
        tar -xzf "$SELECTED" -C "$PANEL_DIR"
        chown -R www-data:www-data "$PANEL_DIR"
        chmod -R 755 "$PANEL_DIR"
        chmod 644 "$PANEL_DIR/.htaccess" 2>/dev/null
        chmod -R 775 "$PANEL_DIR/database" "$PANEL_DIR/db" 2>/dev/null
        systemctl restart apache2
        echo -e "  ${GREEN}✓ Restauración completa${NC}"
    fi
    sleep 3
}

