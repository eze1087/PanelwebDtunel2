</IfModule>
<IfModule mod_php8.c>
    php_value memory_limit 1024M
    php_value max_execution_time 0
    php_value max_input_time 600
    php_value post_max_size 210M
    php_value upload_max_filesize 200M
</IfModule>
<IfModule mod_php7.c>
    php_value memory_limit 1024M
    php_value max_execution_time 0
    php_value max_input_time 600
    php_value post_max_size 210M
    php_value upload_max_filesize 200M
</IfModule>
HTEOF
        # .user.ini para PHP-FPM
        cat > "$PANEL_DIR/.user.ini" << 'INIEOF'
upload_max_filesize = 200M
post_max_size = 210M
max_execution_time = 0
max_input_time = 600
memory_limit = 1024M
INIEOF
        chown -R www-data:www-data "$PANEL_DIR"
        chmod -R 755 "$PANEL_DIR"
        chmod 644 "$PANEL_DIR/.htaccess" "$PANEL_DIR/.user.ini"
        chmod -R 775 "$PANEL_DIR/database" "$PANEL_DIR/db" 2>/dev/null
        # Eliminar ProxyTimeout si quedó de versiones anteriores
        sed -i '/ProxyTimeout/d' /etc/apache2/sites-available/000-default.conf 2>/dev/null
        # Actualizar el comando panel en /usr/local/bin
        if [ -f "$PANEL_DIR/dtpanel" ]; then
